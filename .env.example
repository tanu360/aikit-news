# Required: Exa API key used by `/api/search` and `/api/deep-research`.
# Get one from https://dashboard.exa.ai/
EXA_API_KEY=your_exa_api_key_here

# Server-side ChatJimmy proxy settings.
# The hosted proxy is OpenAI-compatible and includes tool-calling support.
# This free shared key is intentionally public for AiKit News demos.
CHATJIMMY_API_URL=https://jimmy.aikit.club/v1/chat/completions
CHATJIMMY_API_KEY=tarun-007007
CHATJIMMY_MODEL=llama3.1-8B

# Public model name shown in chat input UI.
NEXT_PUBLIC_MODEL_NAME=llama3.1-8B

# Public production URL used for canonical, Open Graph, and Twitter metadata.
# Keep this as the deployed website origin, without a trailing slash.
NEXT_PUBLIC_SITE_URL=https://news.aikit.club
